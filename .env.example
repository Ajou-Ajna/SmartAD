GEMINI_API_KEY=replace-with-your-gemini-api-key
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_TIMEOUT_SECONDS=180
GEMINI_MAX_RETRIES=5

SMARTADV_STORAGE_DIR=/opt/smartadv/storage
SMARTADV_ENGINE_ROOT_DIR=/opt/smartadv/app
SMARTADV_ENGINE_COMMAND=poetry run python
SMARTADV_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://your-ec2-public-dns

WHISPER_CPP_BIN=/opt/whisper.cpp/build/bin/whisper-cli
WHISPER_MODEL=/opt/whisper.cpp/models/ggml-small.bin
SMARTADV_ENABLE_STT=1

EDGE_TTS_VOICE=ko-KR-SunHiNeural
EDGE_TTS_SPEED=1.0
TTS_START_OFFSET_MS=300
MAX_ATEMPO_SPEED=1.3
TTS_VOLUME=1.25
ORIGINAL_AUDIO_DUCK_THRESHOLD=0.02
ORIGINAL_AUDIO_DUCK_RATIO=8.0
ORIGINAL_AUDIO_DUCK_ATTACK_MS=15
ORIGINAL_AUDIO_DUCK_RELEASE_MS=350

VITE_API_PROXY_TARGET=http://localhost:8080
